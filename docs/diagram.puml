@startuml
title Nexup Backend Challenge - Domain Model (Refinado)

skinparam classAttributeIconSize 0
hide empty members

package "Domain::Models" {

  class Product {
    +id: Long
    +name: String
    +price: BigDecimal
  }

  class OpenHours {
    +daysOpen: Set<DayOfWeek>
    +openTime: LocalTime
    +closeTime: LocalTime
    +isOpen(day: DayOfWeek, time: LocalTime): Boolean
  }

  class Sale {
    +id: Long
    +productId: Long
    +quantity: Int
    +unitPrice: BigDecimal
    +timestamp: LocalDate
    +totalPrice: BigDecimal <<derived>>
  }

  class SupermarketProduct {
    +productId: Long
    -stock: Int
    +increaseStock(quantity: Int): Unit
    +decreaseStock(quantity: Int): Unit
    +hasStock(quantity: Int): Boolean
    +currentStock(): Int
  }

  class Supermarket {
    +id: Long
    +name: String
    +chainId: Long
    -products: MutableList<SupermarketProduct>
    -sales: MutableList<Sale>
    +hours: OpenHours?
    --
    +getProducts(): List<SupermarketProduct>
    +getSales(): List<Sale>
    +addProduct(productId: Long, initialStock: Int): Unit
    +increaseStock(productId: Long, quantity: Int): Unit
    +sellProduct(productId: Long, quantity: Int, unitPrice: BigDecimal): Sale
    -findProduct(productId: Long): SupermarketProduct
  }

  class SupermarketChain {
    +id: Long
    +name: String
  }
}



' =========================
' Relaciones de dominio
' =========================

Supermarket "1" *-- "0..*" SupermarketProduct : products
Supermarket "1" *-- "0..*" Sale : sales
Supermarket "1" -- "0..1" OpenHours : hours

SupermarketChain "1" -- "0..*" Supermarket : chainId (logical)

SupermarketProduct --> Product : productId
Sale --> Product : productId


@enduml